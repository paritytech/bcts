{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs",
  "name": "Blockchain Commons Multipart UR for TypeScript",
  "includeVersion": true,
  "readme": "README.md",
  "exclude": ["**/*.test.ts", "**/tests/**", "**/node_modules/**"],
  "excludePrivate": true,
  "categorizeByGroup": true,
  "defaultCategory": "Other",
  "sort": ["source-order"],
  "cleanOutputDir": true,
  "gitRevision": "main",
  "plugin": []
}
